# ─── App ────────────────────────────────────────────────────
APP_NAME=chatbot-api
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here

# ─── LLM Provider ───────────────────────────────────────────
LLM_PROVIDER=gemini               # openai | anthropic | gemini

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Vector Store ───────────────────────────────────────────
VECTOR_STORE_TYPE=chroma          # chroma | faiss
CHROMA_PERSIST_DIR=./data/chroma

# ─── Meta MongoDB (base de datos interna de la API) ─────────
META_MONGODB_URI=mongodb://localhost:27017
META_MONGODB_DB=chatbot_meta

# ─── RAG ────────────────────────────────────────────────────
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# ─── Schema Introspection ───────────────────────────────────
SCHEMA_SAMPLE_DOCS=5
SCHEMA_MAX_DEPTH=3

# ─── Platform DB connections ────────────────────────────────
ACHO_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
ACHO_MONGO_DB=achoDev

GENCAMPUS_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/gencampus?retryWrites=true&w=majority
GENCAMPUS_MONGO_DB=gencampus

GENLIVE_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/live-events-v1?retryWrites=true&w=majority
GENLIVE_MONGO_DB=live-events-v1
